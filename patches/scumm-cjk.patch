diff --git a/engines/scumm/cjk_cht.h b/engines/scumm/cjk_cht.h
new file mode 100644
index 00000000..03c46299
--- /dev/null
+++ b/engines/scumm/cjk_cht.h
@@ -0,0 +1,40 @@
+/* Indiana Jones and the Fate of Atlantis — Traditional Chinese (Big5) overlay.
+ *
+ * Non-upstream localisation helper. The scumm engine already renders 2-byte CJK
+ * (loadCJKFont / get2byteCharPtr / printChar); this module supplies (a) the Big5
+ * linear glyph index that matches the bitmap font built by tools/build_cjk_font.py,
+ * and (b) an English->Big5 lookup so drawString() can swap translated UI text in
+ * place before the existing renderer draws it. See PLAN.md Phase 3.
+ */
+#ifndef SCUMM_CJK_CHT_H
+#define SCUMM_CJK_CHT_H
+
+#include "common/scummsys.h"
+
+namespace Common { class SeekableReadStream; }
+
+namespace Scumm {
+namespace CHT {
+
+// Load the English->Big5 dictionary from a `atlantis_zh.tab` data stream.
+// Format: one entry per line, `english<TAB>big5bytes`; blank lines and lines
+// starting with '#' are ignored. Replaces any previously loaded table. The
+// engine calls this once at font-load time; a missing file just means the
+// built-in MVP fallback table is used.
+void loadTable(Common::SeekableReadStream *s);
+
+// Big5 -> linear glyph index, identical to tools/build_cjk_font.py:
+//   lead  0x81..0xFE                       (126 leads)
+//   trail 0x40..0x7E -> 0..62 | 0xA1..0xFE -> 63..156   (157 per lead)
+// Returns -1 for a byte pair that is not a valid Big5 character.
+int big5LinearIndex(byte lead, byte trail);
+
+// Replace an English UI string in `buf` with its Big5 translation, in place,
+// when an exact (whitespace-trimmed) match exists. No-op otherwise.
+// `buf` is a NUL-terminated C string with room for `cap` bytes.
+void translateInPlace(byte *buf, int cap);
+
+} // namespace CHT
+} // namespace Scumm
+
+#endif
diff --git a/engines/scumm/cjk_cht.cpp b/engines/scumm/cjk_cht.cpp
new file mode 100644
index 00000000..0472dd26
--- /dev/null
+++ b/engines/scumm/cjk_cht.cpp
@@ -0,0 +1,203 @@
+/* Indiana Jones and the Fate of Atlantis — Traditional Chinese (Big5) overlay.
+ * See cjk_cht.h. Non-upstream localisation helper. */
+
+#include "scumm/cjk_cht.h"
+#include "common/util.h"
+#include "common/str.h"
+#include "common/hashmap.h"
+#include "common/hash-str.h"
+#include "common/stream.h"
+#include "common/file.h"
+#include "common/textconsole.h"
+
+namespace Scumm {
+namespace CHT {
+
+// Dev aid: if a file named "atlantis_dump_on" is on the search path (drop one in
+// the game dir), log every *untranslated* lookup key once via warning(), tagged
+// CHTMISS. Harvest the exact English strings the engine draws (grep the log) and
+// translate those — no guessing from the offline corpus. Off (zero cost) otherwise.
+// Uses only ScummVM-portable APIs (forbidden.h bans getenv/fopen/fprintf).
+static void dumpMiss(const Common::String &key) {
+	static int on = -1;
+	if (on < 0)
+		on = Common::File::exists("atlantis_dump_on") ? 1 : 0;
+	if (!on)
+		return;
+	static Common::HashMap<Common::String, bool> seen;
+	if (seen.contains(key))
+		return;
+	seen[key] = true;
+	warning("%s", (Common::String("CHTMISS\t") + key).c_str());
+}
+
+int big5LinearIndex(byte lead, byte trail) {
+	if (lead < 0x81 || lead > 0xFE)
+		return -1;
+	int to;
+	if (trail >= 0x40 && trail <= 0x7E)
+		to = trail - 0x40;          // 0..62
+	else if (trail >= 0xA1 && trail <= 0xFE)
+		to = 63 + (trail - 0xA1);   // 63..156
+	else
+		return -1;
+	return (lead - 0x81) * 157 + to;
+}
+
+// Built-in MVP fallback: the nine verbs + "Walk to", so the UI is Chinese even
+// before the external dictionary (atlantis_zh.tab) is shipped. The data file,
+// when present, is loaded on top of this and overrides/extends it.
+struct Entry { const char *en; const char *big5; };
+static const Entry kBuiltin[] = {
+	{ "Give",    "\xb5\xb9" },          // 給
+	{ "Pick up", "\xae\xb3\xb0\x5f" },  // 拿起
+	{ "Use",     "\xa8\xcf\xa5\xce" },  // 使用
+	{ "Open",    "\xb6\x7d" },          // 開
+	{ "Talk to", "\xa5\xe6\xbd\xcd" },  // 交談
+	{ "Push",    "\xb1\xc0" },          // 推
+	{ "Close",   "\xc3\xf6" },          // 關
+	{ "Look at", "\xac\xdd" },          // 看
+	{ "Pull",    "\xa9\xd4" },          // 拉
+	{ "Walk to", "\xa8\xab\xa6\x56" },  // 走向
+};
+
+// Verb keys eligible to act as "<verb> <object>" sentence-line prefixes.
+static const char *const kVerbs[] = {
+	"Walk to", "Pick up", "Look at", "Talk to", "Give", "Use", "Open", "Close", "Push", "Pull"
+};
+
+typedef Common::HashMap<Common::String, Common::String> Dict;
+
+static Dict &dict() {
+	static Dict g_dict;
+	static bool g_init = false;
+	if (!g_init) {
+		for (uint i = 0; i < ARRAYSIZE(kBuiltin); i++)
+			g_dict[kBuiltin[i].en] = kBuiltin[i].big5;
+		g_init = true;
+	}
+	return g_dict;
+}
+
+void loadTable(Common::SeekableReadStream *s) {
+	if (!s)
+		return;
+	Dict &d = dict();
+	int n = 0;
+	while (!s->eos()) {
+		Common::String line = s->readLine();
+		if (line.empty() || line[0] == '#')
+			continue;
+		const char *tab = strchr(line.c_str(), '\t');
+		if (!tab)
+			continue;
+		Common::String en(line.c_str(), tab - line.c_str());
+		Common::String zh(tab + 1);
+		en.trim();
+		// keep zh as-is (Big5 bytes); only strip a trailing CR if present
+		while (!zh.empty() && (zh.lastChar() == '\r' || zh.lastChar() == '\n'))
+			zh.deleteLastChar();
+		if (!en.empty() && !zh.empty())
+			d[en] = zh;
+		n++;
+	}
+	(void)n;
+}
+
+static const char *exactLookup(const Common::String &key) {
+	Dict &d = dict();
+	Dict::const_iterator it = d.find(key);
+	return (it != d.end()) ? it->_value.c_str() : nullptr;
+}
+
+// Canonical lookup key: drop SCUMM control sequences (0xFF + code [+ 2 args]),
+// collapse whitespace runs to one space, trim. Must match the exact same
+// normalisation done by tools/build_translation.py so multi-line dialogue
+// (which carries 0xFF 0x01 newlines) still matches a single-line TSV key.
+static Common::String normalizeKey(const byte *buf) {
+	Common::String k;
+	bool lastSpace = true;
+	int i = 0;
+	while (buf[i]) {
+		byte c = buf[i];
+		if (c == 0xFF) {
+			byte code = buf[i + 1];
+			if (code == 0x04 || code == 0x06 || code == 0x07 ||
+				code == 0x09 || code == 0x0A || code == 0x0C || code == 0x0E)
+				i += 4;          // control byte + 2 arg bytes
+			else
+				i += 2;          // bare control (newline/keep/wait/...)
+			if (!lastSpace) { k += ' '; lastSpace = true; }
+			continue;
+		}
+		// Any control byte (<=0x20), DEL (0x7F), or '^' (0x5E, used in the source
+		// text as a line-break/space marker) collapses to a single separator.
+		if (c <= 0x20 || c == 0x7F || c == 0x5E) {
+			if (!lastSpace) { k += ' '; lastSpace = true; }
+			i++;
+			continue;
+		}
+		k += (char)c;
+		lastSpace = false;
+		i++;
+	}
+	while (!k.empty() && k.lastChar() == ' ')
+		k.deleteLastChar();
+	return k;
+}
+
+void translateInPlace(byte *buf, int cap) {
+	if (!buf || !buf[0])
+		return;
+
+	if (Common::File::exists("atlantis_dump_raw")) {
+		Common::String hex;
+		for (int i = 0; buf[i] && i < 80; i++) {
+			char b[4];
+			Common::sprintf_s(b, "%02x", buf[i]);
+			hex += b;
+		}
+		warning("%s", (Common::String("CHTRAW\t") + hex).c_str());
+	}
+
+	Common::String key = normalizeKey(buf);
+	if (key.empty())
+		return;
+
+	// 1) Whole-string match (verbs, full object names, dialogue lines).
+	if (const char *hit = exactLookup(key)) {
+		Common::String out(hit);
+		if ((int)out.size() + 1 <= cap) {
+			memcpy(buf, out.c_str(), out.size());
+			buf[out.size()] = 0;
+		}
+		return;
+	}
+
+	// 2) Sentence line "<verb> <object>": translate the verb prefix, then the
+	//    object (leave the object in English if we don't know it yet).
+	for (uint i = 0; i < ARRAYSIZE(kVerbs); i++) {
+		Common::String pfx(kVerbs[i]);
+		pfx += ' ';
+		if (key.hasPrefix(pfx)) {
+			Common::String object(key.c_str() + pfx.size());
+			const char *verbBig5 = exactLookup(kVerbs[i]);
+			const char *objBig5 = exactLookup(object);
+			Common::String out(verbBig5 ? verbBig5 : kVerbs[i]);
+			out += ' ';
+			out += objBig5 ? objBig5 : object;
+			if ((int)out.size() + 1 <= cap) {
+				memcpy(buf, out.c_str(), out.size());
+				buf[out.size()] = 0;
+			}
+			if (!objBig5)
+				dumpMiss(object);   // object name still untranslated — harvest it
+			return;
+		}
+	}
+
+	dumpMiss(key);   // nothing matched — harvest for translation
+}
+
+} // namespace CHT
+} // namespace Scumm
